# ============================================================================
# Discord Bot Configuration - 請在這裡填入你的 Discord Bot 設定
# ============================================================================

# Bot Token - 取得方式：https://discord.com/developers/applications
# 點選你的應用程式 → Bot → Copy Token
DISCORD_TOKEN=

# Discord Application ID - 你的 Bot 應用程式 ID
# 取得方式：https://discord.com/developers/applications → 你的應用程式 → APPLICATION ID
DISCORD_CLIENT_ID=

# Discord Guild ID - 僅用於 development 模式快速測試
# 留空可跳過此步驟，但 development 模式需要此設定
# 取得方式：在你的 Discord 伺服器內右鍵 → 複製伺服器 ID（需啟用開發者模式）
DISCORD_GUILD_ID=

# 環境設定 - development（快速測試 Guild Commands）或 production（Global Commands）
# 預設值：development
DISCORD_ENV=development

# ============================================================================
# Bot Display Settings - 機器人展示設定（可選）
# ============================================================================

# Bot 品牌名稱 - 預設會在 /setup 後由伺服器管理員設定
# BOT_BRAND_NAME=Discord Bot

# Bot 狀態類型 - WATCHING, PLAYING, LISTENING, COMPETING
# BOT_ACTIVITY_TYPE=WATCHING

# Bot 狀態文字
# BOT_ACTIVITY_TEXT=Discord Bot | /help

# 只在啟動時主動註冊 Slash Commands；預設關閉，建議使用 scripts/deploy-commands.js
# DISCORD_AUTO_REGISTER_COMMANDS=false

# ============================================================================
# 其他設定（可選）- 這些設定會在之後版本改為 /setup 指令
# ============================================================================

# 工作室網站（留空表示不設定）
# STUDIO_WEBSITE_URL=

# 工作室 Discord 邀請連結（留空表示不設定）
# STUDIO_INVITE_URL=
